{
  "family": "payflow-notifications",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "payflow-notifications",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/payflow-notifications:latest",
      "environment": [
        {
          "name": "SPRING_KAFKA_BOOTSTRAP_SERVERS",
          "value": "KAFKA_BROKER_HOST:9092"
        },
        {
          "name": "SPRING_REDIS_HOST",
          "value": "REDIS_HOST"
        },
        {
          "name": "SPRING_REDIS_PORT",
          "value": "6379"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/payflow-notifications",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "pgrep java || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "essential": true
    }
  ]
}
